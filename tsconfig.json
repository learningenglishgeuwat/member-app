{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.mts",
    ".next_build/types/**/*.ts",
    ".next_build/dev/types/**/*.ts",
    ".next_dev/types/**/*.ts",
    ".next_dev/dev/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".d/types/**/*.ts",
    ".d/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next_build",
    ".next_dev",
    ".x",
    ".x/**",
    ".d",
    ".d/**",
    "d",
    "d/**",
    "backups",
    "backups/**/*"
  ]
}
