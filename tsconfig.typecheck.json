{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": [
      "node",
      "jest",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "next-env.d.ts",
    "*.ts",
    "*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "scripts/**/*.ts",
    "scripts/**/*.mts",
    "types/**/*.ts",
    "types/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next_build",
    ".next_dev",
    ".x",
    ".d",
    "d",
    "backups",
    "backups/**/*"
  ]
}
